# ── Sanity CMS (optional — site works without these) ──────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token

# ── Email / Contact Form (Nodemailer + SMTP) ───────────────────────────────
# Gmail: use an App Password (myaccount.google.com → Security → App Passwords)
# Outlook / Office 365: host = smtp.office365.com, port = 587
# Any SMTP provider works — just change host/port

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password

# Where contact form submissions are delivered (defaults to SMTP_USER if blank)
CONTACT_EMAIL=hello@forma-studio.com
